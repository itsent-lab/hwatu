{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/family-hwatu/game-rule-vectors-v1.schema.json",
  "title": "Family Hwatu game rule vectors v1",
  "type": "object",
  "required": ["contract", "version", "cases"],
  "properties": {
    "contract": { "const": "family-hwatu-game-rule-vectors" },
    "version": { "const": 1 },
    "sourceDate": { "type": "string", "format": "date" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "case": {
      "type": "object",
      "required": ["id", "operation", "description", "input", "expected"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
        "operation": {
          "enum": ["captured-score", "matgo-settlement", "gostop-settlement", "gostop-balance"]
        },
        "description": { "type": "string", "minLength": 1 },
        "input": { "type": "object" },
        "expected": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
